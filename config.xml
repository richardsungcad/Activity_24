<?xml version='1.0' encoding='utf-8'?>
<widget id="com.richardmerchandisehub.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/cordova">
    <name>Richard Merchandise Hub</name>
    <description>
        A merchandise inventory management application
    </description>
    <author email="app@richardmerchandisehub.com" href="http://richardmerchandisehub.com">
        Richard Merchandise Hub Team
    </author>
    <content src="index.html" />
    <plugin name="cordova-plugin-whitelist" spec="1" />
    <plugin name="cordova-plugin-camera" spec="latest" />
    <plugin name="cordova-plugin-file" spec="latest" />
    <plugin name="cordova-plugin-file-transfer" spec="latest" />
    <plugin name="cordova-plugin-dialogs" spec="latest" />
    
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
        <icon src="res/icon/android/icon.png" density="ldpi" />
        <icon src="res/icon/android/icon.png" density="mdpi" />
        <icon src="res/icon/android/icon.png" density="hdpi" />
        <icon src="res/icon/android/icon.png" density="xhdpi" />
        <icon src="res/icon/android/icon.png" density="xxhdpi" />
        <icon src="res/icon/android/icon.png" density="xxxhdpi" />
    </platform>
    <preference name="SplashScreenDelay" value="0" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="ShowSplashScreenSpinner" value="false" />
    <preference name="android-minSdkVersion" value="21" />
</widget>
